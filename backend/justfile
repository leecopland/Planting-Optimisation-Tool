set dotenv-load := true
# Set the shell only for Windows
set windows-shell := ["powershell.exe", "-NoLogo", "-Command"]

export PYTHONUTF8 := "1"
export PYTHONPATH := "."

# Variable definitions using direct OS detection
PYTHON          := if os() == "windows" { "python" } else { "python3" }
UV_RUNNER       := "uv run"
ALEMBIC_CMD     := UV_RUNNER + " alembic"

SERVICE_NAME    := "db"
CONTAINER_NAME  := "pot_postgres_db"

FASTAPI_TARGET  := "src/main.py"
DEFAULT_PORT    := env("API_PORT", "8080")

# Standard recipe to avoid Shebang/CRLF issues
[private]
ensure-env:
    @{{PYTHON}} -c "import os, shutil; \
    not os.path.exists('.env') and os.path.exists('.env.example') and \
    (shutil.copy('.env.example', '.env'), print('--- Created .env from .env.example ---'))"

# Restarts the DB container and applies any pending migrations (data is preserved)
setup: ensure-env stop start migrate
    @echo "--- Setup/Update Complete ---"

# Stops the current PostgreSQL Container
stop:
    @echo "--- Stopping PostgreSQL Container (Preserving Data) ---"
    @docker compose down
    @echo "--- PostgreSQL Container Stopped ---"

# Starts the PostgreSQL Container
start:
    @echo "--- Starting PostgreSQL Container ---"
    @docker compose up -d {{SERVICE_NAME}}
    @echo "Waiting for DB to be ready..."
    @{{PYTHON}} -c "import time; time.sleep(5)"

# Migrates the database (alembic migration scripts)
migrate: ensure-env
    @echo "--- Applying Schema Migration ---"
    @{{ALEMBIC_CMD}} upgrade head
    @echo "--- Schema Migrated ---"

# Destroys the database to a clean slate and applies migrations
reset: ensure-env
    @echo "--- WARNING: Wiping Database and Volumes ---"
    @docker compose down -v
    @just start
    @just migrate

# Generates a revision script (For structural changes to the DB)
revision message: ensure-env
    @echo "--- Generating New Migration Script ---"
    @{{ALEMBIC_CMD}} revision --autogenerate -m "{{message}}"
    @echo "--- Migration Script generated---"

# Generates an empty migration for manual edits (e.g. column renames).
# After running, open the generated file in alembic/versions/ and fill in the upgrade/downgrade functions, then run just migrate.
rename-column: ensure-env
    @echo "--- Generating empty migration for manual edit ---"
    @{{ALEMBIC_CMD}} revision -m "MANUAL_RENAME_REQUIRED"

# Clones the database and runs the pytest suite
test: ensure-env
    @{{UV_RUNNER}} {{PYTHON}} -m src.scripts.replicate_db

# Starts an interactive PSQL session
psql: ensure-env
    @docker exec -it {{CONTAINER_NAME}} psql -U postgres -d POT_db

# Generates a schema from the current ORM models
schema: ensure-env
    @echo "--- Generating SCHEMA.md from Models ---"
    @{{UV_RUNNER}} {{PYTHON}} -m src.generate_schema > SCHEMA.md
    @echo "--- SCHEMA.md generated ---"

# Generates an Entity-Relationship Diagram of the current database
erd: ensure-env
    @echo "--- Generating ERD.md ---"
    @{{PYTHON}} -c "print('# Entity Relationship Diagram\n\n' + chr(96)*3 + 'mermaid')" > ERD.md
    @{{UV_RUNNER}} paracelsus graph src.database:Base --import-module "src.models:*" >> ERD.md
    @{{PYTHON}} -c "print(chr(96)*3)" >> ERD.md
    @echo "--- ERD.md created successfully. ---"

# Starts the FastAPI server. Optionally pass a port: just run-api 9000 (default: 8080, or API_PORT from .env)
run-api port=DEFAULT_PORT: ensure-env
    -@{{UV_RUNNER}} fastapi dev {{FASTAPI_TARGET}} --port {{port}} --host 0.0.0.0

# WARNING: Destructive. Wipes the database and re-populates from scratch. Optionally pass a port: just populate 9000 (default: 8080, or API_PORT from .env)
populate port=DEFAULT_PORT: ensure-env
    @echo "Preparing data ingestion environment..."
    @just reset
    @{{UV_RUNNER}} {{PYTHON}} -m src.scripts.seed_references
    @{{UV_RUNNER}} {{PYTHON}} -m src.scripts.create_test_user
    @{{UV_RUNNER}} {{PYTHON}} -m src.scripts.setup_import_db {{port}}
    @just kill-api {{port}}
    @echo "--- Ingestion Complete, Verifying Stats ---"
    @{{UV_RUNNER}} {{PYTHON}} -m src.scripts.check_data_stats
    @echo "Database is ready and populated. To start dev server run: just run-api"

# Stops the API server. Optionally pass a port: just kill-api 9000 (default: 8080, or API_PORT from .env)
kill-api port=DEFAULT_PORT:
    @echo "Attempting to stop API server..."
    @{{UV_RUNNER}} {{PYTHON}} -m src.scripts.kill-api {{port}}