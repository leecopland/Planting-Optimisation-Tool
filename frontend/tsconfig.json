{
  "compilerOptions": {
    "rootDir": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@@/*": ["./*"]
    },
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "strict": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["vite/client", "node", "vitest/globals"]
  },
  "include": ["src", "vite.config.ts", "src/test"],
  "exclude": ["node_modules", ".history/**"]
}
